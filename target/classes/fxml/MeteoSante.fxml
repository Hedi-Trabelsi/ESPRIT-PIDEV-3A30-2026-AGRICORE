<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true"
            style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controller.MeteoSanteController">
    <VBox spacing="20" style="-fx-padding:25; -fx-background-color: #f4f6f9;">

        <!-- TITRE -->
        <HBox alignment="CENTER_LEFT" spacing="15">
            <Label text="Meteo et Sante Animale"
                   style="-fx-font-size:22px;-fx-font-weight:bold;-fx-text-fill:#1a237e;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Retour" onAction="#navigateBack"
                    style="-fx-background-color:#546e7a;-fx-text-fill:white;
                           -fx-font-weight:bold;-fx-padding:10 18;
                           -fx-background-radius:10;-fx-cursor:hand;"/>
        </HBox>

        <Separator/>

        <!-- BARRE DE RECHERCHE -->
        <HBox spacing="12" alignment="CENTER_LEFT"
              style="-fx-background-color:white;-fx-background-radius:15;-fx-padding:20;
                     -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.08),8,0,0,2);">
            <TextField fx:id="villeTf"
                       promptText="Entrez votre ville (ex: Tunis, Sfax, Paris...)"
                       prefWidth="420"
                       style="-fx-background-radius:8;-fx-padding:11;
                              -fx-border-color:#ddd;-fx-border-radius:8;-fx-font-size:14px;"/>
            <Button fx:id="btnMeteo" text="Analyser les risques"
                    onAction="#rechercherMeteo"
                    style="-fx-background-color:#1565c0;-fx-text-fill:white;
                           -fx-font-weight:bold;-fx-padding:12 22;
                           -fx-background-radius:10;-fx-cursor:hand;-fx-font-size:13px;"/>
            <ProgressIndicator fx:id="progressIndicator" prefWidth="32" prefHeight="32"/>
        </HBox>

        <!-- RESULTATS -->
        <VBox fx:id="meteoBox" spacing="20">

            <!-- LIGNE 1 : Meteo + Risques -->
            <HBox spacing="20">
                <!-- Carte Meteo -->
                <VBox spacing="15" HBox.hgrow="ALWAYS"
                      style="-fx-background-color:white;-fx-background-radius:15;-fx-padding:20;
                             -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.08),8,0,0,2);">
                    <Label text="Conditions Meteo Actuelles"
                           style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:#333;"/>
                    <HBox alignment="CENTER_LEFT" spacing="25">
                        <Label fx:id="lblIconeMeteo" text=""
                               style="-fx-font-size:55px;"/>
                        <VBox spacing="6">
                            <Label fx:id="lblVille" text="-"
                                   style="-fx-font-size:17px;-fx-font-weight:bold;-fx-text-fill:#333;"/>
                            <Label fx:id="lblTempExt" text="-C"
                                   style="-fx-font-size:28px;-fx-font-weight:bold;"/>
                            <Label fx:id="lblDescription" text="-"
                                   style="-fx-font-size:12px;-fx-text-fill:#666;"/>
                        </VBox>
                    </HBox>
                    <HBox spacing="20">
                        <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS"
                              style="-fx-background-color:#e3f2fd;-fx-padding:12;-fx-background-radius:10;">
                            <Label text="Humidite" style="-fx-text-fill:#555;-fx-font-size:11px;-fx-font-weight:bold;"/>
                            <Label fx:id="lblHumidite" text="-%"
                                   style="-fx-font-weight:bold;-fx-text-fill:#1565c0;-fx-font-size:18px;"/>
                        </VBox>
                        <VBox alignment="CENTER" spacing="4" HBox.hgrow="ALWAYS"
                              style="-fx-background-color:#e8f5e9;-fx-padding:12;-fx-background-radius:10;">
                            <Label text="Vent" style="-fx-text-fill:#555;-fx-font-size:11px;-fx-font-weight:bold;"/>
                            <Label fx:id="lblVent" text="- km/h"
                                   style="-fx-font-weight:bold;-fx-text-fill:#2e7d32;-fx-font-size:18px;"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Carte Risques -->
                <VBox spacing="10" HBox.hgrow="ALWAYS"
                      style="-fx-background-color:white;-fx-background-radius:15;-fx-padding:20;
                             -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.08),8,0,0,2);">
                    <Label text="Risques Sanitaires Detectes"
                           style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:#c62828;"/>
                    <VBox fx:id="risquesBox" spacing="8"/>
                </VBox>
            </HBox>

            <!-- LIGNE 2 : Conseils -->
            <VBox spacing="10"
                  style="-fx-background-color:white;-fx-background-radius:15;-fx-padding:20;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.08),8,0,0,2);">
                <Label text="Conseils et Actions Recommandees"
                       style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:#1565c0;"/>
                <VBox fx:id="conseilsBox" spacing="6"/>
            </VBox>

            <!-- LIGNE 3 : Correlation par animal -->
            <VBox spacing="12"
                  style="-fx-background-color:white;-fx-background-radius:15;-fx-padding:20;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.08),8,0,0,2);">
                <VBox spacing="3">
                    <Label text="Correlation avec vos animaux"
                           style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:#333;"/>
                    <Label text="Croisement des conditions meteo avec le dernier suivi de chaque animal"
                           style="-fx-font-size:11px;-fx-text-fill:#888;"/>
                </VBox>
                <VBox fx:id="alertesAnimauxBox" spacing="10"/>
            </VBox>
        </VBox>

        <!-- INFO BAS DE PAGE -->
        <HBox spacing="12" alignment="CENTER_LEFT"
              style="-fx-background-color:#e3f2fd;-fx-background-radius:10;-fx-padding:15;">
            <VBox spacing="3">
                <Label text="API OpenWeatherMap"
                       style="-fx-font-weight:bold;-fx-text-fill:#1565c0;-fx-font-size:12px;"/>
                <Label text="1000 appels gratuits/jour - Donnees mises a jour toutes les 10 minutes"
                       style="-fx-text-fill:#555;-fx-font-size:11px;"/>
            </VBox>
        </HBox>

    </VBox>
</ScrollPane>
