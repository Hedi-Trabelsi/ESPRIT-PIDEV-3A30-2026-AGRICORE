<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true"
            style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controller.RecommandationAlimentaireController">

    <VBox spacing="20" style="-fx-padding: 30; -fx-background-color: #f8f9fa;">

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="15">
            <VBox>
                <Label text="Nutrition IA - Recommandations Alimentaires"
                       style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2d3436;"/>
                <Label text="Systeme expert de recommandation nutritionnelle pour vos animaux"
                       style="-fx-text-fill: #a0a0a0; -fx-font-size: 12px;"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Retour" onAction="#navigateBack"
                    style="-fx-background-color: #546e7a; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 18; -fx-background-radius: 10; -fx-cursor: hand;"/>
        </HBox>

        <Separator/>

        <!-- Formulaire -->
        <VBox spacing="15" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 25;
                                   -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
            <Label text="Parametres de l'animal" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2e7d32;"/>

            <HBox spacing="15">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Animal" style="-fx-text-fill: #666;"/>
                    <ComboBox fx:id="comboAnimal" maxWidth="Infinity" promptText="Choisir un animal..."
                              style="-fx-background-radius: 8; -fx-border-color: #e0e0e0; -fx-border-radius: 8;"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Age (ans)" style="-fx-text-fill: #666;"/>
                    <TextField fx:id="ageTf" promptText="Ex: 3"
                               style="-fx-background-radius: 8; -fx-padding: 10; -fx-border-color: #e0e0e0; -fx-border-radius: 8;"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Poids (kg)" style="-fx-text-fill: #666;"/>
                    <TextField fx:id="poidsTf" promptText="Ex: 450"
                               style="-fx-background-radius: 8; -fx-padding: 10; -fx-border-color: #e0e0e0; -fx-border-radius: 8;"/>
                </VBox>
            </HBox>

            <HBox spacing="15">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Etat de sante" style="-fx-text-fill: #666;"/>
                    <ComboBox fx:id="etatCombo" maxWidth="Infinity" promptText="Etat..."
                              style="-fx-background-radius: 8; -fx-border-color: #e0e0e0; -fx-border-radius: 8;"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Niveau d'activite" style="-fx-text-fill: #666;"/>
                    <ComboBox fx:id="niveauCombo" maxWidth="Infinity" promptText="Niveau..."
                              style="-fx-background-radius: 8; -fx-border-color: #e0e0e0; -fx-border-radius: 8;"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Saison" style="-fx-text-fill: #666;"/>
                    <ComboBox fx:id="saisonCombo" maxWidth="Infinity"
                              style="-fx-background-radius: 8; -fx-border-color: #e0e0e0; -fx-border-radius: 8;"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Objectif" style="-fx-text-fill: #666;"/>
                    <ComboBox fx:id="objectifCombo" maxWidth="Infinity" promptText="Objectif..."
                              style="-fx-background-radius: 8; -fx-border-color: #e0e0e0; -fx-border-radius: 8;"/>
                </VBox>
            </HBox>

            <HBox spacing="15" alignment="CENTER">
                <Button text="Generer la recommandation" onAction="#genererRecommandation"
                        style="-fx-background-color: #2e7d32; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 30; -fx-background-radius: 10; -fx-cursor: hand; -fx-font-size: 14px;"/>
                <Button text="Reinitialiser" onAction="#reset"
                        style="-fx-background-color: #eceff1; -fx-text-fill: #546e7a; -fx-font-weight: bold; -fx-padding: 12 20; -fx-background-radius: 10; -fx-cursor: hand;"/>
            </HBox>
        </VBox>

        <!-- Resultats -->
        <VBox fx:id="resultBox" spacing="20">

            <!-- Info Animal + Score -->
            <HBox spacing="20">
                <VBox spacing="10" HBox.hgrow="ALWAYS"
                      style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
                    <Label text="Animal selectionne" style="-fx-font-weight: bold; -fx-text-fill: #333;"/>
                    <Label fx:id="lblAnimalInfo" text="" style="-fx-font-size: 13px; -fx-text-fill: #555;"/>
                </VBox>
                <VBox spacing="5" alignment="CENTER" minWidth="180"
                      style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
                    <Label text="Score Nutritionnel" style="-fx-font-weight: bold; -fx-text-fill: #333;"/>
                    <Label fx:id="lblScoreNutri" text="" style="-fx-font-size: 32px; -fx-font-weight: bold;"/>
                    <Label fx:id="lblStatutNutri" text="" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
                </VBox>
            </HBox>

            <!-- Aliments recommandes -->
            <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20;
                                       -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
                <Label text="Aliments recommandes" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #2e7d32;"/>
                <VBox fx:id="alimentsBox" spacing="5"/>
            </VBox>

            <!-- Supplements -->
            <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20;
                                       -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
                <Label text="Supplements et vitamines" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #1565c0;"/>
                <VBox fx:id="supplementsBox" spacing="5"/>
            </VBox>

            <!-- Interdits -->
            <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20;
                                       -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
                <Label text="Aliments interdits" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #c62828;"/>
                <VBox fx:id="interditsBox" spacing="5"/>
            </VBox>

            <!-- Plan alimentaire -->
            <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20;
                                       -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
                <Label text="Plan alimentaire" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #555;"/>
                <VBox fx:id="planBox" spacing="5"/>
            </VBox>

            <!-- Rapport complet -->
            <VBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20;
                                       -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 8, 0, 0, 2);">
                <Label text="Rapport complet" style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                <TextArea fx:id="txtRapport" prefHeight="200" editable="false" wrapText="true"
                          style="-fx-background-radius: 8; -fx-border-color: #e0e0e0; -fx-border-radius: 8;"/>
            </VBox>
        </VBox>

    </VBox>
</ScrollPane>
