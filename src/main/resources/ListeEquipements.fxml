<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<AnchorPane prefHeight="760.0" prefWidth="1250.0"
            style="-fx-background-color: #f0f7ee;"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.ListeEquipementsController">
    <children>

        <!-- ===== SIDEBAR ===== -->
        <VBox prefHeight="760.0" prefWidth="230.0"
              style="-fx-background-color: linear-gradient(to bottom, #1e3a1a, #3a6b2e, #4a7c40);"
              spacing="0.0">
            <children>

                <!-- Logo / Brand -->
                <VBox alignment="CENTER" prefHeight="130.0"
                      style="-fx-background-color: rgba(0,0,0,0.25); -fx-border-color: rgba(255,255,255,0.08); -fx-border-width: 0 0 1 0;">
                    <padding><Insets top="20" bottom="20"/></padding>
                    <ImageView fitHeight="52.0" fitWidth="52.0" pickOnBounds="true" preserveRatio="true">
                        <image><Image url="@/images/logo.png" /></image>
                    </ImageView>
                    <Label text="AgroManager" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: white; -fx-padding: 6 0 2 0;" />
                    <Label text="Espace Fournisseur" style="-fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.55); -fx-font-weight: bold; -fx-letter-spacing: 1;" />
                </VBox>

                <!-- Profile mini card -->
                <HBox alignment="CENTER_LEFT" spacing="10.0"
                      style="-fx-background-color: rgba(255,255,255,0.07); -fx-padding: 14 18; -fx-border-color: rgba(255,255,255,0.06); -fx-border-width: 0 0 1 0;">
                    <Label text="👤" style="-fx-font-size: 22px;" />
                    <VBox spacing="2.0">
                        <Label text="Fournisseur" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: white;" />
                        <Label text="Compte actif" style="-fx-font-size: 10px; -fx-text-fill: #7ddc6e;" />
                    </VBox>
                </HBox>

                <!-- Navigation section -->
                <VBox spacing="2.0">
                    <padding><Insets top="18" left="14" right="14" bottom="10"/></padding>
                    <children>
                        <Label text="NAVIGATION" style="-fx-font-size: 9px; -fx-text-fill: rgba(255,255,255,0.4); -fx-font-weight: bold; -fx-padding: 0 0 8 6; -fx-letter-spacing: 1;" />

                        <!-- Liste Equipements (ACTIVE) -->
                        <HBox spacing="12.0" alignment="CENTER_LEFT"
                              style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 11 15; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.2), 6, 0, 0, 2);">
                            <Label text="🚜" style="-fx-font-size: 16px;" />
                            <Label text="Liste Équipements" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #3a6b2e;" />
                        </HBox>

                        <!-- Ajouter -->
                        <HBox spacing="12.0" alignment="CENTER_LEFT"
                              style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 10; -fx-padding: 11 15; -fx-cursor: hand;"
                              onMouseClicked="#goToAjout">
                            <Label text="➕" style="-fx-font-size: 16px;" />
                            <Label text="Ajouter Équipement" style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.9);" />
                        </HBox>

                        <HBox spacing="12.0" alignment="CENTER_LEFT"
                              style="-fx-background-color: rgba(255,255,255,0.06); -fx-background-radius: 10; -fx-padding: 11 15; -fx-cursor: hand; -fx-opacity: 0.65;">
                            <Label text="👥" style="-fx-font-size: 16px;" />
                            <Label text="Gestion Utilisateurs" style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.85);" />
                        </HBox>

                        <HBox spacing="12.0" alignment="CENTER_LEFT"
                              style="-fx-background-color: rgba(255,255,255,0.06); -fx-background-radius: 10; -fx-padding: 11 15; -fx-cursor: hand; -fx-opacity: 0.65;">
                            <Label text="⚙️" style="-fx-font-size: 16px;" />
                            <Label text="Gestion Maintenance" style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.85);" />
                        </HBox>

                        <HBox spacing="12.0" alignment="CENTER_LEFT"
                              style="-fx-background-color: rgba(255,255,255,0.06); -fx-background-radius: 10; -fx-padding: 11 15; -fx-cursor: hand; -fx-opacity: 0.65;">
                            <Label text="📅" style="-fx-font-size: 16px;" />
                            <Label text="Gestion Événements" style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.85);" />
                        </HBox>

                        <HBox spacing="12.0" alignment="CENTER_LEFT"
                              style="-fx-background-color: rgba(255,255,255,0.06); -fx-background-radius: 10; -fx-padding: 11 15; -fx-cursor: hand; -fx-opacity: 0.65;">
                            <Label text="🐄" style="-fx-font-size: 16px;" />
                            <Label text="Gestion Animaux" style="-fx-font-size: 13px; -fx-text-fill: rgba(255,255,255,0.85);" />
                        </HBox>
                    </children>
                </VBox>

                <Region VBox.vgrow="ALWAYS" />

                <!-- Bottom stats -->
                <VBox style="-fx-background-color: rgba(0,0,0,0.2); -fx-padding: 14 18; -fx-border-color: rgba(255,255,255,0.08); -fx-border-width: 1 0 0 0;" spacing="8.0">
                    <Label fx:id="labelEquipCount"
                           style="-fx-font-size: 12px; -fx-text-fill: rgba(255,255,255,0.8); -fx-font-weight: bold;" />
                    <Button text="← Changer de rôle" onAction="#goToLogin"
                            style="-fx-background-color: rgba(255,255,255,0.12); -fx-text-fill: white; -fx-background-radius: 10; -fx-font-size: 12px; -fx-cursor: hand; -fx-padding: 9 16; -fx-border-color: rgba(255,255,255,0.25); -fx-border-radius: 10;"
                            maxWidth="Infinity" />
                </VBox>
            </children>
        </VBox>

        <!-- ===== MAIN CONTENT ===== -->
        <VBox layoutX="230.0" layoutY="0.0" prefHeight="760.0" prefWidth="1020.0"
              style="-fx-background-color: #f0f7ee;" spacing="0.0">
            <children>

                <!-- Top Bar -->
                <HBox alignment="CENTER_LEFT" spacing="14.0"
                      style="-fx-background-color: white; -fx-padding: 16 24; -fx-border-color: #ddeedd; -fx-border-width: 0 0 1 0; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 8, 0, 0, 2);">
                    <VBox spacing="2.0" HBox.hgrow="ALWAYS">
                        <Label text="📋 Liste des Équipements"
                               style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #1e3a1a;" />
                        <Label text="Gérez, modifiez et suivez vos équipements agricoles"
                               style="-fx-font-size: 12px; -fx-text-fill: #7a9c70;" />
                    </VBox>

                    <!-- Taux de change inline (compact) -->
                    <HBox spacing="8.0" alignment="CENTER"
                          style="-fx-background-color: #f5f9f4; -fx-background-radius: 10; -fx-padding: 8 14; -fx-border-color: #c8ddc5; -fx-border-radius: 10;">
                        <Label text="💱" style="-fx-font-size: 13px;" />
                        <Label fx:id="labelTauxEUR" text="1 TND = ... EUR"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #2d5a25;" />
                        <Label text="|" style="-fx-text-fill: #ccc;" />
                        <Label fx:id="labelTauxUSD" text="1 TND = ... USD"
                               style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #1565c0;" />
                        <Label fx:id="labelMajTaux" text="" style="-fx-font-size: 9px; -fx-text-fill: #aaa;" />
                    </HBox>

                    <Button text="📊 Stats" onAction="#afficherStats"
                            style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-weight: bold; -fx-font-size: 12px; -fx-cursor: hand; -fx-padding: 9 16;" />
                    <Button text="📄 PDF" onAction="#exporterPDF"
                            style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-weight: bold; -fx-font-size: 12px; -fx-cursor: hand; -fx-padding: 9 16;" />
                    <Button text="+ Ajouter" onAction="#goToAjout"
                            style="-fx-background-color: #4a7c40; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-weight: bold; -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 9 20;" />
                </HBox>

                <!-- Stats Panel (hidden by default) -->
                <VBox fx:id="panelStats" visible="false" managed="false"
                      style="-fx-background-color: white; -fx-border-color: #ddeedd; -fx-border-width: 0 0 1 0;"
                      spacing="6.0">
                    <padding><Insets top="12" right="20" bottom="12" left="20"/></padding>
                    <children>
                        <HBox alignment="CENTER_LEFT">
                            <Label text="Statistiques par type d'équipement"
                                   style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #3a6b2e;" HBox.hgrow="ALWAYS" />
                            <Button text="✕ Fermer" onAction="#fermerStats"
                                    style="-fx-background-color: #ecf0f1; -fx-text-fill: #7f8c8d; -fx-background-radius: 8; -fx-font-size: 11px; -fx-cursor: hand; -fx-padding: 4 10;" />
                        </HBox>
                        <BarChart fx:id="barChart" prefHeight="180.0"
                                  style="-fx-background-color: transparent;">
                            <xAxis><CategoryAxis label="Type" /></xAxis>
                            <yAxis><NumberAxis label="Quantité totale" /></yAxis>
                        </BarChart>
                    </children>
                </VBox>

                <!-- Search / Filter Bar -->
                <HBox alignment="CENTER_LEFT" spacing="12.0"
                      style="-fx-background-color: #f5fbf3; -fx-padding: 14 24; -fx-border-color: #ddeedd; -fx-border-width: 0 0 1 0;">
                    <Label text="🔍" style="-fx-font-size: 14px;" />
                    <TextField fx:id="fieldSearch" promptText="Rechercher par nom ou type..."
                               prefWidth="300.0"
                               style="-fx-background-color: white; -fx-border-color: #c8ddc5; -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 8 14; -fx-font-size: 13px;"
                               onKeyReleased="#filterTable" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label text="Vue en grille" style="-fx-font-size: 11px; -fx-text-fill: #888;" />
                </HBox>

                <!-- GRID VIEW -->
                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-background: #f0f7ee;">
                    <content>
                        <VBox style="-fx-background-color: #f0f7ee;">
                            <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>
                            <children>
                                <!-- FlowPane for grid cards -->
                                <FlowPane fx:id="gridEquipements"
                                          hgap="16.0" vgap="16.0"
                                          prefWrapLength="950.0"
                                          style="-fx-background-color: transparent;" />

                                <!-- Empty placeholder -->
                                <VBox fx:id="emptyPlaceholder" alignment="CENTER" spacing="12.0"
                                      visible="false" managed="false"
                                      style="-fx-padding: 80 0;">
                                    <Label text="🚜" style="-fx-font-size: 60px;" />
                                    <Label text="Aucun équipement trouvé"
                                           style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #9ab890;" />
                                    <Label text="Ajoutez votre premier équipement en cliquant sur '+ Ajouter'"
                                           style="-fx-font-size: 12px; -fx-text-fill: #b0c8a8;" />
                                </VBox>
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>

            </children>
        </VBox>

    </children>
</AnchorPane>
