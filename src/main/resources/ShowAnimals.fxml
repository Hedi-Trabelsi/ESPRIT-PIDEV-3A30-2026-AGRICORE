<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="600.0" prefWidth="1210.0"
            style="-fx-background-color: #7ca76f;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.ShowAnimalsController">

    <children>

        <!-- ================= MENU GAUCHE ================= -->

        <VBox prefHeight="600.0" prefWidth="216.0" spacing="20.0">

            <children>

                <VBox alignment="CENTER" prefHeight="126.0">
                    <children>
                        <Label text="LOGO"
                               style="-fx-font-size:18px; -fx-font-weight:bold;"/>
                    </children>
                </VBox>

                <Button text="Gestion Utilisateurs"
                        prefWidth="200"
                        style="-fx-background-color: transparent; -fx-text-fill: white;"/>

                <Button text="Gestion Équipements"
                        prefWidth="200"
                        style="-fx-background-color: transparent; -fx-text-fill: white;"/>

                <Button text="Gestion Maintenance"
                        prefWidth="200"
                        style="-fx-background-color: transparent; -fx-text-fill: white;"/>

                <Button text="Gestion Événements"
                        prefWidth="200"
                        style="-fx-background-color: transparent; -fx-text-fill: white;"/>

                <Button text="Gestion Animaux"
                        prefWidth="200"
                        style="-fx-background-color: white; -fx-text-fill: black;"/>

                <Button text="Gestion Financière"
                        prefWidth="200"
                        style="-fx-background-color: transparent; -fx-text-fill: white;"/>

            </children>
        </VBox>

        <!-- ================= CONTENU DROIT ================= -->

        <VBox layoutX="217.0"
              prefHeight="600.0"
              prefWidth="980.0"
              spacing="20"
              style="-fx-background-color: white; -fx-background-radius: 25; -fx-padding: 20;">

            <children>

                <!-- Titre + bouton ajouter -->
                <HBox alignment="CENTER_LEFT" spacing="20">
                    <children>

                        <Label text="Liste des Animaux"
                               style="-fx-font-size:20px; -fx-font-weight:bold;"/>

                        <Button text="Ajouter Animal"
                                onAction="#navigateAddAnimal"
                                style="-fx-background-color:#7ca76f; -fx-text-fill:white; -fx-background-radius:10;"/>

                    </children>
                </HBox>

                <!-- ✅ LISTVIEW À LA PLACE DU TABLEVIEW -->

                <ListView fx:id="animalListView"
                          prefHeight="450"
                          prefWidth="900"
                          style="-fx-background-radius: 15;"/>

            </children>

        </VBox>

    </children>

</AnchorPane>