<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="1210.0"
            style="-fx-background-color: #7ca76f;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.DashboardController">

    <!-- Sidebar -->
    <VBox prefHeight="600.0" prefWidth="216.0" spacing="20.0">
        <children>
            <VBox alignment="CENTER" prefHeight="126.0" prefWidth="216.0">
                <children>
                    <ImageView fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@images/logo.png" />
                        </image>
                    </ImageView>
                </children>
            </VBox>

            <!-- Other buttons... -->

            <!-- Gestion Événements Button -->
            <HBox alignment="CENTER" prefHeight="44.0" prefWidth="216.0">
                <children>
                    <ImageView fitHeight="28.0" fitWidth="23.0" pickOnBounds="true" preserveRatio="true" translateX="35.0">
                        <image>
                            <Image url="@images/booking.png" />
                        </image>
                    </ImageView>
                    <Button fx:id="btnGestionEvenements" mnemonicParsing="false" onAction="#showGestionEvenements"
                            prefHeight="27.0" prefWidth="194.0"
                            style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-background-radius: 15;"
                            text="Gestion Événements" textFill="WHITE" />
                </children>
            </HBox>

        </children>
    </VBox>

    <!-- Main content area -->
    <VBox layoutX="217.0" layoutY="4.0" prefHeight="590.0" prefWidth="988.0">
        <children>
            <ScrollPane fitToWidth="true" fitToHeight="true" prefHeight="598.0" prefWidth="996.0">
                <content>
                    <VBox fx:id="mainContentVBox" spacing="20" style="-fx-background-color: white; -fx-background-radius: 25; -fx-padding: 10;" />
                </content>
            </ScrollPane>
        </children>
    </VBox>

</AnchorPane>
