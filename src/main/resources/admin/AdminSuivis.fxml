<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="720.0" prefWidth="1200.0"
            style="-fx-background-color:#1a1a2e;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.admin.AdminSuivisController">
    <children>

        <!-- ══ SIDEBAR ══ -->
        <VBox prefHeight="720.0" prefWidth="220.0"
              style="-fx-background-color:#16213e;">
            <children>
                <VBox alignment="CENTER" prefHeight="100"
                      style="-fx-background-color:#0f3460;-fx-padding:20;">
                    <Label text="⚙️ ADMIN PANEL"
                           style="-fx-font-size:16px;-fx-font-weight:bold;-fx-text-fill:white;"/>
                    <Label text="Gestion Élevage"
                           style="-fx-font-size:11px;-fx-text-fill:#aaa;"/>
                </VBox>
                <VBox spacing="5" style="-fx-padding:15 10;">
                    <Button text="📊  Dashboard" maxWidth="Infinity"
                            onAction="#navigateDashboard"
                            style="-fx-background-color:transparent;-fx-text-fill:#aaa;
                                   -fx-padding:12 16;-fx-alignment:CENTER-LEFT;
                                   -fx-background-radius:8;-fx-cursor:hand;-fx-font-size:13px;"/>
                    <Button text="🐾  Gestion Animaux" maxWidth="Infinity"
                            onAction="#navigateAnimaux"
                            style="-fx-background-color:transparent;-fx-text-fill:#aaa;
                                   -fx-padding:12 16;-fx-alignment:CENTER-LEFT;
                                   -fx-background-radius:8;-fx-cursor:hand;-fx-font-size:13px;"/>
                    <Button text="📋  Gestion Suivis" maxWidth="Infinity"
                            style="-fx-background-color:#0f3460;-fx-text-fill:white;
                                   -fx-font-weight:bold;-fx-padding:12 16;-fx-alignment:CENTER-LEFT;
                                   -fx-background-radius:8;-fx-cursor:hand;-fx-font-size:13px;"/>
                </VBox>
            </children>
        </VBox>

        <!-- ══ CONTENU ══ -->
        <VBox layoutX="220" prefHeight="720.0" prefWidth="980.0" spacing="0"
              style="-fx-background-color:#f0f2f5;">

            <!-- Header -->
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-padding:15 25;-fx-background-color:white;
                         -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.05),5,0,0,2);">
                <Label text="📋" style="-fx-font-size:22px;"/>
                <VBox>
                    <Label text="Gestion des Suivis Médicaux"
                           style="-fx-font-size:19px;-fx-font-weight:bold;-fx-text-fill:#1a237e;"/>
                    <Label fx:id="lblCount" text="Chargement..."
                           style="-fx-font-size:12px;-fx-text-fill:#888;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <!-- Filtres -->
                <HBox spacing="8" alignment="CENTER">
                    <ComboBox fx:id="filtreEtatCombo" promptText="Filtrer état..."
                              style="-fx-background-radius:20;-fx-border-color:#e0e0e0;-fx-border-radius:20;"/>
                    <TextField fx:id="searchTf" promptText="🔍 Rechercher..."
                               prefWidth="180"
                               style="-fx-background-radius:20;-fx-padding:8 15;
                                      -fx-border-color:#e0e0e0;-fx-border-radius:20;"/>
                </HBox>
            </HBox>

            <!-- Corps -->
            <HBox spacing="0" VBox.vgrow="ALWAYS">

                <!-- ═ TABLEAU ═ -->
                <VBox HBox.hgrow="ALWAYS" style="-fx-padding:15 15 15 20;">
                    <TableView fx:id="tableSuivis" VBox.vgrow="ALWAYS"
                               style="-fx-background-color:white;-fx-background-radius:12;
                                      -fx-border-color:transparent;
                                      -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.08),8,0,0,2);">
                        <columns>
                            <TableColumn fx:id="colId"       text="ID"/>
                            <TableColumn fx:id="colAnimal"   text="Animal"/>
                            <TableColumn fx:id="colDate"     text="Date"/>
                            <TableColumn fx:id="colTemp"     text="Temp"/>
                            <TableColumn fx:id="colPoids"    text="Poids"/>
                            <TableColumn fx:id="colRythme"   text="Rythme"/>
                            <TableColumn fx:id="colEtat"     text="État"/>
                            <TableColumn fx:id="colActivite" text="Activité"/>
                            <TableColumn fx:id="colActions"  text="Actions"/>
                        </columns>
                        <placeholder>
                            <Label text="Aucun suivi trouvé"
                                   style="-fx-text-fill:#bbb;-fx-font-size:14px;"/>
                        </placeholder>
                    </TableView>
                </VBox>

                <!-- ═ FORMULAIRE DROITE ═ -->
                <ScrollPane prefWidth="290" fitToWidth="true"
                            style="-fx-background-color:#fafafa;-fx-background:#fafafa;
                                   -fx-border-color:#e8e8e8;-fx-border-width:0 0 0 1;">
                    <VBox spacing="12" style="-fx-padding:18;">

                        <Label fx:id="lblFormTitre" text="➕ Ajouter un suivi"
                               style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#1a237e;"/>
                        <Separator/>

                        <VBox spacing="4">
                            <Label text="Animal *" style="-fx-font-weight:bold;-fx-text-fill:#555;-fx-font-size:11px;"/>
                            <ComboBox fx:id="comboAnimal" maxWidth="Infinity" promptText="Choisir..."
                                      style="-fx-background-radius:8;-fx-border-color:#ddd;-fx-border-radius:8;"/>
                        </VBox>

                        <HBox spacing="8">
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="Température *" style="-fx-font-weight:bold;-fx-text-fill:#555;-fx-font-size:11px;"/>
                                <TextField fx:id="tempTf" promptText="38.5"
                                           style="-fx-background-radius:8;-fx-padding:8;-fx-border-color:#ddd;-fx-border-radius:8;"/>
                            </VBox>
                            <VBox spacing="4" HBox.hgrow="ALWAYS">
                                <Label text="Poids (kg) *" style="-fx-font-weight:bold;-fx-text-fill:#555;-fx-font-size:11px;"/>
                                <TextField fx:id="poidsTf" promptText="450"
                                           style="-fx-background-radius:8;-fx-padding:8;-fx-border-color:#ddd;-fx-border-radius:8;"/>
                            </VBox>
                        </HBox>

                        <VBox spacing="4">
                            <Label text="Rythme cardiaque *" style="-fx-font-weight:bold;-fx-text-fill:#555;-fx-font-size:11px;"/>
                            <TextField fx:id="rythmeTf" promptText="70"
                                       style="-fx-background-radius:8;-fx-padding:8;-fx-border-color:#ddd;-fx-border-radius:8;"/>
                        </VBox>

                        <VBox spacing="4">
                            <Label text="État de santé *" style="-fx-font-weight:bold;-fx-text-fill:#555;-fx-font-size:11px;"/>
                            <ComboBox fx:id="etatCombo" maxWidth="Infinity" promptText="Choisir..."
                                      style="-fx-background-radius:8;-fx-border-color:#ddd;-fx-border-radius:8;"/>
                        </VBox>

                        <VBox spacing="4">
                            <Label text="Niveau activité" style="-fx-font-weight:bold;-fx-text-fill:#555;-fx-font-size:11px;"/>
                            <ComboBox fx:id="niveauCombo" maxWidth="Infinity" promptText="Choisir..."
                                      style="-fx-background-radius:8;-fx-border-color:#ddd;-fx-border-radius:8;"/>
                        </VBox>

                        <VBox spacing="4">
                            <Label text="Remarques" style="-fx-font-weight:bold;-fx-text-fill:#555;-fx-font-size:11px;"/>
                            <TextArea fx:id="remarqueTa" prefHeight="65" wrapText="true"
                                      promptText="Observations..."
                                      style="-fx-background-radius:8;-fx-padding:8;
                                             -fx-border-color:#ddd;-fx-border-radius:8;"/>
                        </VBox>

                        <Separator/>

                        <Button fx:id="btnSauvegarder" text="➕ Ajouter"
                                onAction="#sauvegarder" maxWidth="Infinity"
                                style="-fx-background-color:#2e7d32;-fx-text-fill:white;
                                       -fx-font-weight:bold;-fx-padding:11;
                                       -fx-background-radius:10;-fx-cursor:hand;"/>

                        <Button text="🔄 Réinitialiser" onAction="#resetFormulaire"
                                maxWidth="Infinity"
                                style="-fx-background-color:#eceff1;-fx-text-fill:#546e7a;
                                       -fx-font-weight:bold;-fx-padding:9;
                                       -fx-background-radius:10;-fx-cursor:hand;"/>

                    </VBox>
                </ScrollPane>

            </HBox>
        </VBox>
    </children>
</AnchorPane>
