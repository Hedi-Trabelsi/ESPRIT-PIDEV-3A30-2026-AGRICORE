<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="900.0"
            style="-fx-background-color: linear-gradient(to bottom right, #3a6b2e, #7ca76f, #a8d5a0);"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.LoginController">

    <!-- Background decorative circles -->
    <children>

        <!-- Top decorative circle -->
        <javafx.scene.shape.Circle centerX="50.0" centerY="50.0" radius="120.0"
                                   fill="rgba(255,255,255,0.05)" />
        <javafx.scene.shape.Circle centerX="850.0" centerY="550.0" radius="160.0"
                                   fill="rgba(255,255,255,0.05)" />

        <!-- Main centered VBox -->
        <VBox alignment="CENTER" spacing="40.0"
              AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
              AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0">

            <!-- Logo + Title -->
            <VBox alignment="CENTER" spacing="12.0">
                <ImageView fitHeight="100.0" fitWidth="100.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@/images/logo.png" />
                    </image>
                </ImageView>
                <Label text="AgriCore" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: white; -fx-font-family: 'Segoe UI';" />
                <Label text="Plateforme de gestion agricole" style="-fx-font-size: 15px; -fx-text-fill: rgba(255,255,255,0.80); -fx-font-family: 'Segoe UI';" />
            </VBox>

            <!-- Role selection title -->
            <Label text="Choisissez votre espace"
                   style="-fx-font-size: 18px; -fx-text-fill: rgba(255,255,255,0.9); -fx-font-family: 'Segoe UI'; -fx-font-weight: bold;" />

            <!-- Role Cards -->
            <HBox spacing="40.0" alignment="CENTER">

                <!-- Fournisseur Card -->
                <VBox fx:id="cardFournisseur" alignment="CENTER" spacing="16.0"
                      prefWidth="220.0" prefHeight="220.0"
                      onMouseClicked="#goToFournisseur"
                      style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 20, 0, 0, 5); -fx-cursor: hand; -fx-padding: 30;">
                    <ImageView fitHeight="70.0" fitWidth="70.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@/images/tracktor.png" />
                        </image>
                    </ImageView>
                    <Label text="Fournisseur" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2d5a25; -fx-font-family: 'Segoe UI';" />
                    <Label text="Gérer les équipements" style="-fx-font-size: 12px; -fx-text-fill: #7a9c70; -fx-font-family: 'Segoe UI';" wrapText="true" textAlignment="CENTER" />
                    <Button text="Accéder →" onAction="#goToFournisseur"
                            style="-fx-background-color: #4a7c40; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-weight: bold; -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 8 20;" />
                </VBox>

                <!-- Agriculteur Card -->
                <VBox fx:id="cardAgriculteur" alignment="CENTER" spacing="16.0"
                      prefWidth="220.0" prefHeight="220.0"
                      onMouseClicked="#goToAgriculteur"
                      style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 20, 0, 0, 5); -fx-cursor: hand; -fx-padding: 30;">
                    <ImageView fitHeight="70.0" fitWidth="70.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@/images/paw.png" />
                        </image>
                    </ImageView>
                    <Label text="Agriculteur" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2d5a25; -fx-font-family: 'Segoe UI';" />
                    <Label text="Parcourir &amp; commander" style="-fx-font-size: 12px; -fx-text-fill: #7a9c70; -fx-font-family: 'Segoe UI';" wrapText="true" textAlignment="CENTER" />
                    <Button text="Accéder →" onAction="#goToAgriculteur"
                            style="-fx-background-color: #4a7c40; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-weight: bold; -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 8 20;" />
                </VBox>

            </HBox>

            <!-- Footer -->
            <Label text="© 2026 AgriCore — Tous droits réservés"
                   style="-fx-font-size: 11px; -fx-text-fill: rgba(255,255,255,0.5); -fx-font-family: 'Segoe UI';" />
        </VBox>

    </children>
</AnchorPane>
