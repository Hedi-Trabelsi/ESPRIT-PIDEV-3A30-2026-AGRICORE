<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="740.0" prefWidth="1210.0"
            style="-fx-background-color: #7ca76f;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.TraitementNaturelController">
    <children>

        <!-- ══ MENU GAUCHE ══ -->
        <VBox prefHeight="740.0" prefWidth="216.0" spacing="20.0">
            <children>
                <VBox alignment="CENTER" prefHeight="126.0">
                    <Label text="LOGO" style="-fx-font-size:18px;-fx-font-weight:bold;-fx-text-fill:white;"/>
                </VBox>
                <Button text="Gestion Utilisateurs" prefWidth="200" style="-fx-background-color:transparent;-fx-text-fill:white;"/>
                <Button text="Gestion Équipements"  prefWidth="200" style="-fx-background-color:transparent;-fx-text-fill:white;"/>
                <Button text="Gestion Maintenance"  prefWidth="200" style="-fx-background-color:transparent;-fx-text-fill:white;"/>
                <Button text="Gestion Événements"   prefWidth="200" style="-fx-background-color:transparent;-fx-text-fill:white;"/>
                <Button text="Gestion Animaux"      prefWidth="200" style="-fx-background-color:white;-fx-text-fill:black;"/>
                <Button text="Gestion Financière"   prefWidth="200" style="-fx-background-color:transparent;-fx-text-fill:white;"/>
            </children>
        </VBox>

        <!-- ══ CONTENU ══ -->
        <ScrollPane layoutX="217.0" prefHeight="740.0" prefWidth="980.0"
                    fitToWidth="true"
                    style="-fx-background-color:#f4f6f9;-fx-background:#f4f6f9;">
            <VBox spacing="20" style="-fx-padding:25;">

                <!-- TITRE -->
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <Label text="🌿" style="-fx-font-size:32px;"/>
                    <VBox>
                        <Label text="Conseiller Traitement Naturel IA"
                               style="-fx-font-size:22px;-fx-font-weight:bold;-fx-text-fill:#1a237e;"/>
                        <Label text="Powered by Groq LLaMA 3 — Remèdes naturels, plantes médicinales et prévention"
                               style="-fx-font-size:12px;-fx-text-fill:#888;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="← Retour" onAction="#navigateBack"
                            style="-fx-background-color:#546e7a;-fx-text-fill:white;
                                   -fx-font-weight:bold;-fx-padding:10 18;
                                   -fx-background-radius:10;-fx-cursor:hand;"/>
                </HBox>

                <Separator/>

                <!-- ══ 2 COLONNES ══ -->
                <HBox spacing="20">

                    <!-- ═ FORMULAIRE GAUCHE ═ -->
                    <VBox spacing="15" minWidth="400" HBox.hgrow="SOMETIMES"
                          style="-fx-background-color:white;-fx-background-radius:15;-fx-padding:20;
                                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.08),8,0,0,2);">

                        <Label text="📋 Informations du cas"
                               style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:#333;"/>

                        <!-- Animal -->
                        <VBox spacing="4">
                            <Label text="🐾 Animal *" style="-fx-font-weight:bold;-fx-text-fill:#555;"/>
                            <ComboBox fx:id="comboAnimal" maxWidth="Infinity"
                                      promptText="Choisir un animal..."
                                      style="-fx-background-radius:8;-fx-border-color:#ddd;-fx-border-radius:8;-fx-padding:5;"/>
                        </VBox>

                        <!-- Pathologie -->
                        <VBox spacing="4">
                            <Label text="🦠 Pathologie / Problème *" style="-fx-font-weight:bold;-fx-text-fill:#555;"/>
                            <ComboBox fx:id="pathologieCombo" maxWidth="Infinity"
                                      promptText="Choisir la pathologie..."
                                      style="-fx-background-radius:8;-fx-border-color:#ddd;-fx-border-radius:8;"/>
                        </VBox>

                        <!-- Gravité -->
                        <VBox spacing="4">
                            <Label text="⚠️ Gravité" style="-fx-font-weight:bold;-fx-text-fill:#555;"/>
                            <ComboBox fx:id="graviteCombo" maxWidth="Infinity"
                                      style="-fx-background-radius:8;-fx-border-color:#ddd;-fx-border-radius:8;"/>
                        </VBox>

                        <!-- Symptômes -->
                        <VBox spacing="4">
                            <Label text="📝 Symptômes supplémentaires (optionnel)"
                                   style="-fx-font-weight:bold;-fx-text-fill:#555;"/>
                            <TextArea fx:id="symptomesTf" prefHeight="80" wrapText="true"
                                      promptText="Décrivez les symptômes observés en détail..."
                                      style="-fx-background-radius:8;-fx-border-color:#ddd;
                                             -fx-border-radius:8;-fx-padding:8;"/>
                        </VBox>

                        <!-- Options -->
                        <VBox spacing="8"
                              style="-fx-background-color:#f5f5f5;-fx-padding:12;-fx-background-radius:10;">
                            <Label text="⚙️ Options" style="-fx-font-weight:bold;-fx-text-fill:#444;"/>
                            <CheckBox fx:id="checkBio" text="🌱 Élevage biologique (privilégier remèdes certifiés bio)"
                                      style="-fx-font-size:12px;"/>
                            <CheckBox fx:id="checkUrgent" text="🚨 Situation urgente (indiquer si intervention rapide nécessaire)"
                                      style="-fx-font-size:12px;"/>
                        </VBox>

                        <!-- Boutons -->
                        <HBox spacing="12">
                            <Button fx:id="btnAnalyser" text="🌿 Obtenir Conseils IA"
                                    onAction="#analyser"
                                    maxWidth="Infinity" HBox.hgrow="ALWAYS"
                                    style="-fx-background-color:#2e7d32;-fx-text-fill:white;
                                           -fx-font-weight:bold;-fx-padding:13;
                                           -fx-background-radius:10;-fx-cursor:hand;-fx-font-size:13px;"/>
                            <Button text="🔄" onAction="#reset"
                                    style="-fx-background-color:#eceff1;-fx-text-fill:#546e7a;
                                           -fx-padding:13 16;-fx-background-radius:10;-fx-cursor:hand;"/>
                        </HBox>

                        <!-- Progress -->
                        <HBox alignment="CENTER">
                            <ProgressIndicator fx:id="progressIndicator" prefWidth="40" prefHeight="40"/>
                        </HBox>

                        <!-- Info API -->
                        <VBox spacing="4"
                              style="-fx-background-color:#e8f5e9;-fx-background-radius:8;-fx-padding:10;">
                            <Label text="🆓 Groq API — 100% Gratuit"
                                   style="-fx-font-weight:bold;-fx-text-fill:#2e7d32;-fx-font-size:12px;"/>
                            <Label text="1. Inscrivez-vous sur console.groq.com"
                                   style="-fx-text-fill:#555;-fx-font-size:11px;"/>
                            <Label text="2. API Keys → Create API Key"
                                   style="-fx-text-fill:#555;-fx-font-size:11px;"/>
                            <Label text="3. Remplacez VOTRE_CLE_GROQ dans le controller"
                                   style="-fx-text-fill:#e65100;-fx-font-size:11px;-fx-font-weight:bold;"/>
                        </VBox>

                    </VBox>

                    <!-- ═ RÉSULTATS DROITE ═ -->
                    <VBox fx:id="resultBox" spacing="15" HBox.hgrow="ALWAYS"
                          style="-fx-background-color:white;-fx-background-radius:15;-fx-padding:20;
                                 -fx-effect:dropshadow(gaussian,rgba(0,0,0,0.08),8,0,0,2);">

                        <Label text="🌿 Recommandations IA"
                               style="-fx-font-size:15px;-fx-font-weight:bold;-fx-text-fill:#333;"/>

                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label fx:id="lblAnimalInfo" text="—"
                                   style="-fx-font-size:12px;-fx-text-fill:#555;-fx-font-weight:bold;"/>
                        </HBox>
                        <Label fx:id="lblPathologie" text="—"
                               style="-fx-font-size:13px;-fx-font-weight:bold;-fx-text-fill:#2e7d32;"/>

                        <Separator/>

                        <!-- Traitements naturels -->
                        <VBox spacing="6"
                              style="-fx-background-color:#e8f5e9;-fx-background-radius:10;-fx-padding:12;">
                            <Label text="💊 Traitements Naturels"
                                   style="-fx-font-weight:bold;-fx-text-fill:#2e7d32;-fx-font-size:13px;"/>
                            <VBox fx:id="traitementsBox" spacing="3"/>
                        </VBox>

                        <!-- Plantes et remèdes -->
                        <VBox spacing="6"
                              style="-fx-background-color:#e3f2fd;-fx-background-radius:10;-fx-padding:12;">
                            <Label text="🌱 Plantes Médicinales &amp; Remèdes"
                                   style="-fx-font-weight:bold;-fx-text-fill:#1565c0;-fx-font-size:13px;"/>
                            <VBox fx:id="plantesBox" spacing="3"/>
                        </VBox>

                        <!-- Prévention -->
                        <VBox spacing="6"
                              style="-fx-background-color:#f3e5f5;-fx-background-radius:10;-fx-padding:12;">
                            <Label text="🛡️ Prévention &amp; Éviter Récidive"
                                   style="-fx-font-weight:bold;-fx-text-fill:#6a1b9a;-fx-font-size:13px;"/>
                            <VBox fx:id="preventionBox" spacing="3"/>
                        </VBox>

                        <!-- Conseils + avertissement -->
                        <Label text="📋 Conseils Pratiques &amp; Avertissements :"
                               style="-fx-font-weight:bold;-fx-text-fill:#444;"/>
                        <TextArea fx:id="txtConseils" prefHeight="180"
                                  editable="false" wrapText="true"
                                  style="-fx-background-color:#fafafa;
                                         -fx-border-color:#e0e0e0;-fx-border-radius:10;
                                         -fx-background-radius:10;-fx-font-size:12px;-fx-padding:10;"/>

                    </VBox>
                </HBox>

            </VBox>
        </ScrollPane>
    </children>
</AnchorPane>
