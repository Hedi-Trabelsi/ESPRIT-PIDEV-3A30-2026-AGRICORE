<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefWidth="1000.0" prefHeight="600.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.FinanceTablesController"
            stylesheets="@tables.css">
    <children>

        <ScrollPane
                fitToWidth="true"
                fitToHeight="false"
                hbarPolicy="NEVER"
                vbarPolicy="AS_NEEDED"
                styleClass="root-scroll"
                AnchorPane.topAnchor="0.0"
                AnchorPane.bottomAnchor="0.0"
                AnchorPane.leftAnchor="0.0"
                AnchorPane.rightAnchor="0.0">
            <content>

                <!--
                    Total minHeight breakdown:
                    padding-top(16) + topbar(40) + gap(16) + feeds(320) + gap(16) + calendar(420) + padding-bottom(16) = 844
                -->
                <VBox spacing="16.0"
                      style="-fx-padding: 16px;"
                      minHeight="844.0"
                      prefHeight="844.0">
                    <children>

                        <!-- Top bar -->
                        <HBox spacing="8.0" alignment="CENTER_LEFT" minHeight="40.0">
                            <children>
                                <Label fx:id="titleLabel" styleClass="page-title" text="Finances"/>
                                <Pane HBox.hgrow="ALWAYS"/>
                                <Button text="← Retour" onAction="#goBack" styleClass="secondary"/>
                            </children>
                        </HBox>

                        <!-- Two-column feed layout -->
                        <HBox spacing="16.0"
                              prefHeight="320.0" minHeight="320.0" maxHeight="320.0">
                            <children>

                                <!-- LEFT: Dépenses -->
                                <VBox styleClass="panel" HBox.hgrow="ALWAYS" maxHeight="320.0">
                                    <children>
                                        <HBox styleClass="panel-header" alignment="CENTER_LEFT" spacing="8.0">
                                            <children>
                                                <Label text="●" styleClass="feed-dot-depense"/>
                                                <Label text="Dépenses" styleClass="panel-title"/>
                                            </children>
                                        </HBox>
                                        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                                                    styleClass="card-scroll">
                                            <content>
                                                <VBox fx:id="depenseFeed" styleClass="feed-list" spacing="0"/>
                                            </content>
                                        </ScrollPane>
                                    </children>
                                </VBox>

                                <!-- RIGHT: Ventes -->
                                <VBox styleClass="panel" HBox.hgrow="ALWAYS" maxHeight="320.0">
                                    <children>
                                        <HBox styleClass="panel-header" alignment="CENTER_LEFT" spacing="8.0">
                                            <children>
                                                <Label text="●" styleClass="feed-dot-vente"/>
                                                <Label text="Ventes" styleClass="panel-title"/>
                                            </children>
                                        </HBox>
                                        <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                                                    styleClass="card-scroll">
                                            <content>
                                                <VBox fx:id="venteFeed" styleClass="feed-list" spacing="0"/>
                                            </content>
                                        </ScrollPane>
                                    </children>
                                </VBox>

                            </children>
                        </HBox>

                        <!-- Calendar panel — bigger -->
                        <VBox styleClass="panel"
                              prefHeight="420.0" minHeight="420.0" maxHeight="420.0">
                            <children>
                                <HBox styleClass="panel-header" alignment="CENTER_LEFT" spacing="8.0">
                                    <children>
                                        <Label text="●" styleClass="feed-dot-vente"/>
                                        <Label text="Calendrier" styleClass="panel-title"/>
                                    </children>
                                </HBox>
                                <AnchorPane fx:id="calendarHost" VBox.vgrow="ALWAYS"
                                            prefHeight="375.0" minHeight="375.0"/>
                            </children>
                        </VBox>

                    </children>
                </VBox>

            </content>
        </ScrollPane>

    </children>
</AnchorPane>
