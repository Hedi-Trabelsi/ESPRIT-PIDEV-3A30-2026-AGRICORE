<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="650.0" prefWidth="1210.0"
            style="-fx-background-color: #5a8f4e;"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.FournisseurController">
    <children>

        <!-- ===== SIDEBAR ===== -->
        <VBox prefHeight="650.0" prefWidth="220.0"
              style="-fx-background-color: linear-gradient(to bottom, #3a6b2e, #5a8f4e);"
              spacing="8.0">
            <padding><Insets top="0" right="0" bottom="20" left="0"/></padding>
            <children>

                <!-- Logo -->
                <VBox alignment="CENTER" prefHeight="120.0" prefWidth="220.0"
                      style="-fx-background-color: rgba(0,0,0,0.15);">
                    <padding><Insets top="15" bottom="15"/></padding>
                    <ImageView fitHeight="60.0" fitWidth="60.0" pickOnBounds="true" preserveRatio="true">
                        <image><Image url="@/images/logo.png" /></image>
                    </ImageView>
                    <Label text="AgriCore" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: white;" />
                    <Label text="Espace Fournisseur" style="-fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.7);" />
                </VBox>

                <VBox spacing="4.0">
                    <padding><Insets top="20" left="12" right="12"/></padding>
                    <children>
                        <Label text="NAVIGATION" style="-fx-font-size: 10px; -fx-text-fill: rgba(255,255,255,0.5); -fx-font-weight: bold; -fx-padding: 0 0 5 8;" />

                        <!-- Equipements (active) -->
                        <HBox spacing="10.0" alignment="CENTER_LEFT"
                              style="-fx-background-color: white; -fx-background-radius: 12; -fx-padding: 10 15; -fx-cursor: hand;"
                              onMouseClicked="#showEquipements">
                            <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                                <image><Image url="@/images/tracktor.png" /></image>
                            </ImageView>
                            <Label text="Gestion Équipements" style="-fx-font-size: 13px; -fx-font-weight: bold; -fx-text-fill: #4a7c40;" />
                        </HBox>

                        <!-- Other modules (grayed) -->
                        <HBox spacing="10.0" alignment="CENTER_LEFT"
                              style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 10 15; -fx-cursor: hand; -fx-opacity: 0.6;"
                              onMouseClicked="#goToLogin">
                            <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                                <image><Image url="@/images/group.png" /></image>
                            </ImageView>
                            <Label text="Gestion Utilisateurs" style="-fx-font-size: 13px; -fx-text-fill: white;" />
                        </HBox>

                        <HBox spacing="10.0" alignment="CENTER_LEFT"
                              style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 10 15; -fx-cursor: hand; -fx-opacity: 0.6;">
                            <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                                <image><Image url="@/images/electricity.png" /></image>
                            </ImageView>
                            <Label text="Gestion Maintenance" style="-fx-font-size: 13px; -fx-text-fill: white;" />
                        </HBox>

                        <HBox spacing="10.0" alignment="CENTER_LEFT"
                              style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 10 15; -fx-cursor: hand; -fx-opacity: 0.6;">
                            <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                                <image><Image url="@/images/booking.png" /></image>
                            </ImageView>
                            <Label text="Gestion Événements" style="-fx-font-size: 13px; -fx-text-fill: white;" />
                        </HBox>

                        <HBox spacing="10.0" alignment="CENTER_LEFT"
                              style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 10 15; -fx-cursor: hand; -fx-opacity: 0.6;">
                            <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                                <image><Image url="@/images/paw.png" /></image>
                            </ImageView>
                            <Label text="Gestion Animaux" style="-fx-font-size: 13px; -fx-text-fill: white;" />
                        </HBox>

                        <HBox spacing="10.0" alignment="CENTER_LEFT"
                              style="-fx-background-color: transparent; -fx-background-radius: 12; -fx-padding: 10 15; -fx-cursor: hand; -fx-opacity: 0.6;">
                            <ImageView fitHeight="20.0" fitWidth="20.0" pickOnBounds="true" preserveRatio="true">
                                <image><Image url="@/images/money-bag.png" /></image>
                            </ImageView>
                            <Label text="Gestion Financière" style="-fx-font-size: 13px; -fx-text-fill: white;" />
                        </HBox>
                    </children>
                </VBox>

                <!-- Spacer -->
                <Region VBox.vgrow="ALWAYS" />

                <!-- Logout button -->
                <HBox alignment="CENTER">
                    <padding><Insets left="12" right="12" bottom="10"/></padding>
                    <Button text="⬅  Changer de rôle" onAction="#goToLogin"
                            style="-fx-background-color: rgba(255,255,255,0.15); -fx-text-fill: white; -fx-background-radius: 10; -fx-font-size: 12px; -fx-cursor: hand; -fx-padding: 8 20; -fx-border-color: rgba(255,255,255,0.3); -fx-border-radius: 10;"
                            maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
                </HBox>
            </children>
        </VBox>

        <!-- ===== MAIN CONTENT ===== -->
        <VBox layoutX="220.0" layoutY="0.0" prefHeight="650.0" prefWidth="990.0" spacing="0">
            <children>
                <!-- White content area -->
                <VBox style="-fx-background-color: #f0f7ee; -fx-background-radius: 0 0 0 0;"
                      prefHeight="650.0" prefWidth="990.0" spacing="20.0">
                    <padding><Insets top="25" right="25" bottom="25" left="25"/></padding>
                    <children>

                        <!-- Header -->
                        <HBox alignment="CENTER_LEFT" spacing="15.0">
                            <VBox spacing="3.0" HBox.hgrow="ALWAYS">
                                <Label text="Gestion des Équipements" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2d5a25;" />
                                <Label text="Ajoutez, modifiez ou supprimez vos équipements agricoles" style="-fx-font-size: 13px; -fx-text-fill: #7a9c70;" />
                            </VBox>
                            <Label fx:id="labelEquipCount"
                                   style="-fx-background-color: #4a7c40; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 6 16; -fx-font-weight: bold; -fx-font-size: 13px;" />
                        </HBox>

                        <!-- Form Card -->
                        <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 15, 0, 0, 4);"
                              spacing="15.0">
                            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                            <children>
                                <Label text="Formulaire d'équipement"
                                       style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #3a6b2e;" />

                                <!-- Row 1 -->
                                <HBox spacing="15.0">
                                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                        <Label text="Nom de l'équipement" style="-fx-font-size: 12px; -fx-text-fill: #5a8a50; -fx-font-weight: bold;" />
                                        <TextField fx:id="fieldNom" promptText="Ex: Tracteur John Deere"
                                                   style="-fx-background-color: #f5f9f4; -fx-border-color: #c8ddc5; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 9 12; -fx-font-size: 13px;" />
                                    </VBox>
                                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                        <Label text="Type" style="-fx-font-size: 12px; -fx-text-fill: #5a8a50; -fx-font-weight: bold;" />
                                        <TextField fx:id="fieldType" promptText="Ex: Machinerie, Outil, Véhicule"
                                                   style="-fx-background-color: #f5f9f4; -fx-border-color: #c8ddc5; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 9 12; -fx-font-size: 13px;" />
                                    </VBox>
                                </HBox>

                                <!-- Row 2 -->
                                <HBox spacing="15.0">
                                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                        <Label text="Prix (TND)" style="-fx-font-size: 12px; -fx-text-fill: #5a8a50; -fx-font-weight: bold;" />
                                        <TextField fx:id="fieldPrix" promptText="Ex: 1500.00"
                                                   style="-fx-background-color: #f5f9f4; -fx-border-color: #c8ddc5; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 9 12; -fx-font-size: 13px;" />
                                    </VBox>
                                    <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                        <Label text="Quantité" style="-fx-font-size: 12px; -fx-text-fill: #5a8a50; -fx-font-weight: bold;" />
                                        <TextField fx:id="fieldQuantite" promptText="Ex: 5"
                                                   style="-fx-background-color: #f5f9f4; -fx-border-color: #c8ddc5; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 9 12; -fx-font-size: 13px;" />
                                    </VBox>
                                </HBox>

                                <!-- Action Buttons -->
                                <HBox spacing="12.0" alignment="CENTER_RIGHT">
                                    <Button text="🗑 Vider" onAction="#clearForm"
                                            style="-fx-background-color: #ecf0f1; -fx-text-fill: #7f8c8d; -fx-background-radius: 10; -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 9 18;" />
                                    <Button fx:id="btnModifier" text="✏ Modifier" onAction="#modifierEquipement"
                                            style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-weight: bold; -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 9 18;"
                                            disable="true" />
                                    <Button text="➕ Ajouter" onAction="#ajouterEquipement"
                                            style="-fx-background-color: #4a7c40; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-weight: bold; -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 9 18;" />
                                </HBox>

                                <!-- Error/success message -->
                                <Label fx:id="labelMessage" text=""
                                       style="-fx-font-size: 13px; -fx-text-fill: #e74c3c;" />
                            </children>
                        </VBox>

                        <!-- Table Card -->
                        <VBox style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 15, 0, 0, 4);"
                              VBox.vgrow="ALWAYS" spacing="12.0">
                            <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="15.0">
                                    <Label text="Liste des équipements"
                                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #3a6b2e;" HBox.hgrow="ALWAYS"/>
                                    <TextField fx:id="fieldSearch" promptText="🔍  Rechercher..."
                                               prefWidth="220.0"
                                               style="-fx-background-color: #f5f9f4; -fx-border-color: #c8ddc5; -fx-border-radius: 20; -fx-background-radius: 20; -fx-padding: 7 12; -fx-font-size: 13px;"
                                               onKeyReleased="#filterTable" />
                                </HBox>

                                <TableView fx:id="tableEquipements" VBox.vgrow="ALWAYS"
                                           style="-fx-background-color: transparent; -fx-border-color: transparent;"
                                           onMouseClicked="#onRowSelected">
                                    <columns>
                                        <TableColumn fx:id="colNom" text="Nom de l'équipement" prefWidth="250" />
                                        <TableColumn fx:id="colType" text="Type" prefWidth="180" />
                                        <TableColumn fx:id="colPrix" text="Prix (TND)" prefWidth="120" />
                                        <TableColumn fx:id="colQuantite" text="Quantité" prefWidth="100" />
                                        <TableColumn fx:id="colActions" text="Actions" prefWidth="160" />
                                    </columns>
                                </TableView>
                            </children>
                        </VBox>

                    </children>
                </VBox>
            </children>
        </VBox>

    </children>
</AnchorPane>
