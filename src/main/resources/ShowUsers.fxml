<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="600.0" prefWidth="1100.0"
            stylesheets="@shadcn.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.ShowUsersController">
    <children>
        <HBox AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <children>
                <AnchorPane HBox.hgrow="ALWAYS"
                            style="-fx-background-color: #eef5f0;">
                    <children>
                        <VBox spacing="16.0"
                              AnchorPane.topAnchor="22.0" AnchorPane.bottomAnchor="22.0"
                              AnchorPane.leftAnchor="24.0" AnchorPane.rightAnchor="24.0">
                            <children>

                                <!-- Top bar -->
                                <HBox alignment="CENTER_LEFT" spacing="12.0"
                                      style="-fx-background-color: #ffffff; -fx-background-radius: 14; -fx-border-color: #c8dfd0; -fx-border-radius: 14; -fx-border-width: 1; -fx-padding: 14 20; -fx-effect: dropshadow(gaussian, rgba(11,51,32,0.08), 10, 0, 0, 3);">
                                    <children>
                                        <HBox spacing="10.0" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Text text="🌿" style="-fx-font-size: 20px;"/>
                                                <VBox spacing="2.0">
                                                    <children>
                                                        <Text text="Utilisateurs"
                                                              style="-fx-font-size: 17px; -fx-font-weight: bold; -fx-fill: #0b3320;"/>
                                                        <Text fx:id="countText" text="membres enregistrés"
                                                              style="-fx-font-size: 11px; -fx-fill: #6b9980;"/>
                                                    </children>
                                                </VBox>
                                            </children>
                                        </HBox>
                                        <HBox spacing="8.0" alignment="CENTER_RIGHT">
                                            <children>
                                                <TextField fx:id="searchField"
                                                           promptText="Rechercher un utilisateur…"
                                                           style="-fx-background-color: #f2f8f4; -fx-background-radius: 9; -fx-border-color: #b8d8c4; -fx-border-radius: 9; -fx-border-width: 1; -fx-text-fill: #0b3320; -fx-prompt-text-fill: #8fb8a0; -fx-padding: 8 14; -fx-font-size: 12px; -fx-pref-width: 230;"/>
                                                <Button text="↺  Rafraîchir"
                                                        onAction="#refreshCards"
                                                        styleClass="btn-refresh-main"/>
                                            </children>
                                        </HBox>
                                    </children>
                                </HBox>

                                <!-- Cards -->
                                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                                            style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                                    <content>
                                        <FlowPane fx:id="cardsPane"
                                                  hgap="16.0" vgap="16.0"
                                                  prefWrapLength="1040.0"
                                                  style="-fx-background-color: transparent; -fx-padding: 2 0 8 0;"/>
                                    </content>
                                </ScrollPane>

                            </children>
                        </VBox>
                    </children>
                </AnchorPane>
            </children>
        </HBox>
    </children>
</AnchorPane>
