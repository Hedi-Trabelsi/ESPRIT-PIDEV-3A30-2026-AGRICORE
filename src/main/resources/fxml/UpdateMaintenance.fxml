<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<AnchorPane prefHeight="720.0" prefWidth="1210.0"
            style="-fx-background-color: #7ca76f;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controller.UpdateMaintenanceController"
            stylesheets="@/styles/styleM.css">



    <!-- Sidebar -->
    <children>
        <VBox prefHeight="680.0" prefWidth="216.0" spacing="20.0" style="-fx-padding: 20;">
            <children>
                <VBox alignment="CENTER" prefHeight="126.0" prefWidth="216.0">
                    <children>
                        <ImageView fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@/images/logo.png" />
                            </image>
                        </ImageView>
                    </children>
                </VBox>
                <HBox alignment="CENTER" prefHeight="44.0" prefWidth="216.0" spacing="10.0">
                    <children>
                        <ImageView fitHeight="28.0" fitWidth="23.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@/images/group.png" />
                            </image>
                        </ImageView>
                        <Button mnemonicParsing="false" prefHeight="27.0" prefWidth="160.0" text="Mon Profil" styleClass="sidebar-button" />
                    </children>
                </HBox>
                <HBox alignment="CENTER" prefHeight="44.0" prefWidth="216.0" spacing="10.0">
                    <children>
                        <ImageView fitHeight="28.0" fitWidth="23.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@/images/tracktor.png" />
                            </image>
                        </ImageView>
                        <Button mnemonicParsing="false" prefHeight="27.0" prefWidth="160.0" text="Équipements" styleClass="sidebar-button" />
                    </children>
                </HBox>
                <HBox alignment="CENTER" prefHeight="44.0" prefWidth="216.0" spacing="10.0">
                    <children>
                        <ImageView fitHeight="28.0" fitWidth="23.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@/images/electricity.png" />
                            </image>
                        </ImageView>
                        <Button mnemonicParsing="false" prefHeight="27.0" prefWidth="160.0" text="Maintenance" styleClass="sidebar-button" />
                    </children>
                </HBox>
                <HBox alignment="CENTER" prefHeight="44.0" prefWidth="216.0" spacing="10.0">
                    <children>
                        <ImageView fitHeight="28.0" fitWidth="23.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@/images/booking.png" />
                            </image>
                        </ImageView>
                        <Button mnemonicParsing="false" prefHeight="27.0" prefWidth="160.0" text="Événements" styleClass="sidebar-button" />
                    </children>
                </HBox>
                <HBox alignment="CENTER" prefHeight="44.0" prefWidth="216.0" spacing="10.0">
                    <children>
                        <ImageView fitHeight="28.0" fitWidth="23.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@/images/paw.png" />
                            </image>
                        </ImageView>
                        <Button mnemonicParsing="false" prefHeight="27.0" prefWidth="160.0" text="Mes Animaux" styleClass="sidebar-button" />
                    </children>
                </HBox>
                <HBox alignment="CENTER" prefHeight="44.0" prefWidth="216.0" spacing="10.0">
                    <children>
                        <ImageView fitHeight="28.0" fitWidth="23.0" pickOnBounds="true" preserveRatio="true">
                            <image>
                                <Image url="@/images/money-bag.png" />
                            </image>
                        </ImageView>
                        <Button mnemonicParsing="false" prefHeight="27.0" prefWidth="160.0" text="Financière" styleClass="sidebar-button" />
                    </children>
                </HBox>
            </children>
        </VBox>

        <!-- Main Content -->
        <!-- Main Content -->
        <!-- Main Content Scrollable -->
        <ScrollPane layoutX="230.0" layoutY="20.0"
                    prefWidth="975.0" prefHeight="680.0"
                    fitToWidth="true"
                    hbarPolicy="NEVER"
                    vbarPolicy="AS_NEEDED">

            <content>
                <VBox prefWidth="950.0"
                      style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 30;"
                      spacing="20.0">

                    <!-- Title -->
                    <HBox alignment="CENTER">
                        <Label text="Modifier la Maintenance" styleClass="form-title"/>
                    </HBox>

                    <!-- Form -->
                    <VBox spacing="25.0" style="-fx-padding: 20;">

                        <!-- Date -->
                        <VBox spacing="8.0">
                            <Label text="Date de Déclaration" styleClass="form-label"/>
                            <DatePicker fx:id="dateDeclarationDp"
                                        prefWidth="450.0"
                                        styleClass="form-input"/>
                        </VBox>

                        <!-- Type -->
                        <VBox spacing="8.0">
                            <Label text="Type de Maintenance" styleClass="form-label"/>
                            <ChoiceBox fx:id="type"
                                       prefWidth="450.0"
                                       styleClass="form-input"/>
                        </VBox>

                        <!-- Lieu -->
                        <VBox spacing="8.0">
                            <Label text="Lieu" styleClass="form-label"/>
                            <TextField fx:id="lieuTf"
                                       prefWidth="450.0"
                                       styleClass="form-input"/>
                        </VBox>

                        <!-- Equipement -->
                        <VBox spacing="8.0">
                            <Label text="Equipement" styleClass="form-label"/>
                            <TextField fx:id="equipementTf"
                                       prefWidth="450.0"
                                       styleClass="form-input"/>
                        </VBox>

                        <!-- Priorité -->
                        <VBox spacing="8.0">
                            <Label text="Priorité" styleClass="form-label"/>
                            <ChoiceBox fx:id="priorite"
                                       prefWidth="450.0"
                                       styleClass="form-input"/>
                        </VBox>

                        <!-- Description -->
                        <VBox spacing="4.0" alignment="TOP_LEFT">
                            <HBox spacing="5" alignment="CENTER_LEFT">
                                <Label text="Description" styleClass="form-label"/>
                            </HBox>
                            <TextArea fx:id="descriptionTf"
                                      prefWidth="450.0"
                                      prefHeight="120.0"
                                      styleClass="form-input"
                                      promptText="Modifier la description..."
                                      wrapText="true" />
                        </VBox>




                        <!-- Buttons -->
                        <HBox spacing="20.0" alignment="CENTER" style="-fx-padding: 20 0 0 0;">
                            <Button text="Mettre à jour"
                                    onAction="#updateMaintenance"
                                    styleClass="btn-primary"
                                    prefWidth="150.0"
                                    prefHeight="45.0"/>
                            <Button text="Annuler"
                                    onAction="#cancelUpdate"
                                    styleClass="btn-secondary"/>
                        </HBox>

                    </VBox>
                </VBox>
            </content>
        </ScrollPane>



    </children>
</AnchorPane>
