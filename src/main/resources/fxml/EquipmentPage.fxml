<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" styleClass="user-content-scroll" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <VBox spacing="25" alignment="TOP_CENTER">
        <padding>
            <Insets top="30" right="40" bottom="40" left="40" />
        </padding>

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="page-header">
            <VBox>
                <Label styleClass="user-page-title" text="Equipment Management" />
                <Label styleClass="user-greeting-label" text="Manage your farm equipment" />
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button text="+ Add Equipment" styleClass="user-primary-button" />
        </HBox>

        <!-- Content Area - To be filled with your friend's work -->
        <VBox styleClass="content-placeholder" alignment="CENTER" prefHeight="400">
            <Label style="-fx-font-size: 18px; -fx-text-fill: #558b2f;" text="🚜 Equipment Management Module" />
            <Label style="-fx-font-size: 14px; -fx-text-fill: #81c784;" text="This area will contain the equipment management interface" />
            <Label style="-fx-font-size: 12px; -fx-text-fill: #a5d6a7;" text="(To be integrated with your friend's work)" />
        </VBox>
    </VBox>
</ScrollPane>