<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:id="rootPane"
           fx:controller="org.example.SignupController"
           prefWidth="1000" prefHeight="650"
           styleClass="root-pane"
           stylesheets="@style.css">

    <VBox alignment="CENTER"
          spacing="25"
          maxWidth="700"
          styleClass="card">

        <padding>
            <Insets top="40" right="60" bottom="40" left="60"/>
        </padding>

        <!-- Title -->
        <VBox alignment="CENTER" spacing="5">
            <Label text="🌱 AGRICOR"
                   styleClass="title-label" />
            <Label text="Create your Smart Agriculture account"
                   styleClass="subtitle-label" />
        </VBox>

        <Separator />

        <!-- FORM -->
        <GridPane hgap="20" vgap="18">

            <columnConstraints>
                <ColumnConstraints percentWidth="50"/>
                <ColumnConstraints percentWidth="50"/>
            </columnConstraints>

            <!-- Nom -->
            <TextField fx:id="nomField"
                       promptText="Nom"
                       styleClass="modern-field"
                       GridPane.columnIndex="0"
                       GridPane.rowIndex="0" />

            <!-- Prenom -->
            <TextField fx:id="prenomField"
                       promptText="Prenom"
                       styleClass="modern-field"
                       GridPane.columnIndex="1"
                       GridPane.rowIndex="0" />

            <!-- Email -->
            <TextField fx:id="emailField"
                       promptText="Email"
                       styleClass="modern-field"
                       GridPane.columnIndex="0"
                       GridPane.rowIndex="1"
                       GridPane.columnSpan="2" />

            <!-- Password -->
            <PasswordField fx:id="passwordField"
                           promptText="Password"
                           styleClass="modern-field"
                           GridPane.columnIndex="0"
                           GridPane.rowIndex="2"
                           GridPane.columnSpan="2" />

            <!-- Confirm Password -->
            <PasswordField fx:id="confirmPasswordField"
                           promptText="Confirm Password"
                           styleClass="modern-field"
                           GridPane.columnIndex="0"
                           GridPane.rowIndex="3"
                           GridPane.columnSpan="2" />

            <!-- Date de naissance -->
            <DatePicker fx:id="datePicker"
                        promptText="Date de naissance"
                        styleClass="modern-field"
                        GridPane.columnIndex="0"
                        GridPane.rowIndex="4" />

            <!-- Genre -->
            <ComboBox fx:id="genreBox"
                      promptText="Genre"
                      styleClass="modern-field"
                      GridPane.columnIndex="1"
                      GridPane.rowIndex="4" />

            <!-- Adresse -->
            <TextField fx:id="adresseField"
                       promptText="Adresse"
                       styleClass="modern-field"
                       GridPane.columnIndex="0"
                       GridPane.rowIndex="5"
                       GridPane.columnSpan="2" />

            <!-- Phone -->
            <TextField fx:id="phoneField"
                       promptText="Numero de telephone"
                       styleClass="modern-field"
                       GridPane.columnIndex="0"
                       GridPane.rowIndex="6"
                       GridPane.columnSpan="2" />

            <!-- Role -->
            <ComboBox fx:id="roleBox"
                      promptText="Select Role"
                      styleClass="modern-field"
                      GridPane.columnIndex="0"
                      GridPane.rowIndex="7"
                      GridPane.columnSpan="2" />

        </GridPane>

        <!-- Create Account Button -->
        <Button text="Create Account"
                fx:id="signupButton"
                prefWidth="240"
                styleClass="primary-button"
                onAction="#handleSignup" />

        <!-- Inline Error Message -->
        <Label fx:id="errorLabel"
               text=""
               visible="false"
               wrapText="true"
               style="-fx-text-fill: red; -fx-font-size: 14px;" />

        <!-- Already have account -->
        <HBox alignment="CENTER" spacing="5">
            <Label text="Already have an account?"
                   styleClass="subtitle-label" />
            <Hyperlink text="Sign In"
                       fx:id="signInLink"
                       styleClass="link-style"
                       onAction="#openSignInPage"/>
        </HBox>

    </VBox>

</StackPane>
