<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.effect.DropShadow?>
<?import javafx.scene.paint.Color?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="Controller.UpdateAnimalController"
           style="-fx-background-color: transparent;">

    <VBox spacing="25" alignment="CENTER" maxWidth="450" maxHeight="620"
          style="-fx-background-color: white; -fx-background-radius: 25; -fx-border-color: #81c784; -fx-border-width: 0.5; -fx-border-radius: 25;">

        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>

        <effect>
            <DropShadow blurType="GAUSSIAN" height="40" radius="19" width="40">
                <color>
                    <Color opacity="0.12" />
                </color>
            </DropShadow>
        </effect>

        <VBox alignment="CENTER" spacing="8">
            <Label text="📝" style="-fx-font-size: 35px;"/>
            <Label text="Modifier la Fiche"
                   style="-fx-text-fill: #388e3c; -fx-font-size: 24px; -fx-font-weight: bold; -fx-font-family: 'System';"/>
            <Label text="Mise à jour des informations de l'animal"
                   style="-fx-text-fill: #888; -fx-font-size: 12px;"/>
        </VBox>

        <Separator maxWidth="200" style="-fx-opacity: 0.4;"/>

        <VBox spacing="15">
            <VBox spacing="5">
                <Label text="Référence Animal (Non modifiable)" style="-fx-text-fill: #2e7d32; -fx-font-weight: bold; -fx-font-size: 11px;"/>
                <TextField fx:id="codeAnimalTf" editable="false"
                           style="-fx-background-color: #f5f5f5; -fx-background-radius: 10; -fx-padding: 12; -fx-text-fill: #999; -fx-border-color: #e0e0e0; -fx-border-radius: 10;"/>
            </VBox>

            <HBox spacing="10">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Espèce" style="-fx-text-fill: #666; -fx-font-size: 11px;"/>
                    <TextField fx:id="especeTf" style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-padding: 12; -fx-border-color: #c8e6c9; -fx-border-radius: 10;"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Race" style="-fx-text-fill: #666; -fx-font-size: 11px;"/>
                    <TextField fx:id="raceTf" style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-padding: 12; -fx-border-color: #c8e6c9; -fx-border-radius: 10;"/>
                </VBox>
            </HBox>

            <HBox spacing="10" alignment="BOTTOM_LEFT">
                <VBox spacing="5" prefWidth="120">
                    <Label text="Sexe" style="-fx-text-fill: #666; -fx-font-size: 11px;"/>
                    <TextField fx:id="sexeTf" style="-fx-background-color: #ffffff; -fx-background-radius: 10; -fx-padding: 12; -fx-border-color: #c8e6c9; -fx-border-radius: 10;"/>
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="Date de Naissance" style="-fx-text-fill: #666; -fx-font-size: 11px;"/>
                    <DatePicker fx:id="datePicker" maxWidth="Infinity" style="-fx-background-radius: 10; -fx-border-color: #c8e6c9; -fx-border-radius: 10;"/>
                </VBox>
            </HBox>
        </VBox>

        <HBox spacing="15" alignment="CENTER">
            <Button text="METTRE À JOUR" onAction="#updateAnimal"
                    HBox.hgrow="ALWAYS" maxWidth="Infinity"
                    style="-fx-background-color: #2e7d32; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 20; -fx-background-radius: 10; -fx-cursor: hand;">
                <effect>
                    <DropShadow height="5" radius="2" color="#00000022"/>
                </effect>
            </Button>

            <Button text="ANNULER" onAction="#navigateShowAnimals"
                    style="-fx-background-color: #ffebee; -fx-text-fill: #c62828; -fx-font-weight: bold; -fx-padding: 12 20; -fx-background-radius: 10; -fx-cursor: hand; -fx-border-color: #ffcdd2; -fx-border-radius: 10;"/>
        </HBox>

    </VBox>
</StackPane>