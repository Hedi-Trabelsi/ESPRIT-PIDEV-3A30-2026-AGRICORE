<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<?import javafx.collections.FXCollections?>
<?import java.lang.String?>
<AnchorPane prefHeight="720" prefWidth="1250" style="-fx-background-color: #7ca76f;"
            stylesheets="@/styles/styleM.css, @/styles/dashboard.css"
            xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controller.NotificationController">

    <children>


        <VBox layoutX="217.0" layoutY="10.0" prefHeight="700.0" prefWidth="1010.0" spacing="20.0"
              style="-fx-background-color: #f8fafc; -fx-background-radius: 15; -fx-padding: 30;">
            <children>
                <VBox spacing="10" alignment="TOP_LEFT">
                    <Button onAction="#closeWindow" text="← Retour"
                            style="-fx-background-color: transparent; -fx-text-fill: #7ca76f; -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 0;"/>

                    <HBox alignment="CENTER_LEFT">
                        <Label text="Demandes en Attente"
                               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>

                <Separator style="-fx-opacity: 0.5;" />

                <HBox alignment="CENTER_LEFT" spacing="15">
                    <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-background-color: #f1f5f9; -fx-padding: 10 15; -fx-background-radius: 12;" HBox.hgrow="ALWAYS">
                        <TextField fx:id="searchField" promptText="Rechercher une demande..."
                                   style="-fx-background-color: transparent; -fx-font-size: 14px;" HBox.hgrow="ALWAYS" />
                    </HBox>

                    <ChoiceBox fx:id="priorityFilter" prefHeight="42.0" prefWidth="160.0"
                               style="-fx-background-color: #f1f5f9; -fx-background-radius: 12; -fx-border-color: transparent; -fx-font-size: 14px;">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="Toutes les priorités" />
                                <String fx:value="Faible" />
                                <String fx:value="Normale" />
                                <String fx:value="Urgente" />
                            </FXCollections>
                        </items>
                        <value>
                            <String fx:value="Toutes les priorités" />
                        </value>
                    </ChoiceBox>

                    <ChoiceBox fx:id="dateSortPicker" prefHeight="42.0" prefWidth="140.0"
                               style="-fx-background-color: #f1f5f9; -fx-background-radius: 12; -fx-border-color: transparent; -fx-font-size: 14px;">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="Plus recent" />
                                <String fx:value="Plus ancien" />
                            </FXCollections>
                        </items>
                        <value>
                            <String fx:value="Plus recent" />
                        </value>
                    </ChoiceBox>
                </HBox>

                <ListView fx:id="notifList" VBox.vgrow="ALWAYS"
                          style="-fx-background-color: transparent; -fx-background-insets: 0; -fx-padding: 0; -fx-border-color: transparent;"/>
            </children>
        </VBox>
    </children>
</AnchorPane>