<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.chart.PieChart?>

<?import javafx.scene.control.Separator?>
<AnchorPane prefHeight="720" prefWidth="1250" style="-fx-background-color: #f8fafc;"
            stylesheets="@/styles/styleM.css, @/styles/dashboard.css"
            xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controller.StatsController">

    <children>


        <VBox layoutX="217.0" layoutY="10.0" prefHeight="700.0" prefWidth="1010.0" spacing="25.0"
              style="-fx-background-color: #f8fafc; -fx-background-radius: 15; -fx-padding: 30;">

            <children>
                <VBox spacing="10" alignment="TOP_LEFT">
                    <Button onAction="#goBack" text="← Retour"
                            style="-fx-background-color: transparent; -fx-text-fill: #7ca76f; -fx-cursor: hand; -fx-font-weight: bold; -fx-font-size: 14px; -fx-padding: 0;"/>

                    <HBox alignment="CENTER_LEFT">
                        <Label text="Analyse des Maintenances"
                               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #1e293b;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                    </HBox>
                </VBox>

                <Separator style="-fx-opacity: 0.5;" />

                <HBox spacing="25" VBox.vgrow="ALWAYS">
                    <children>

                        <VBox HBox.hgrow="ALWAYS"
                              style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                            <children>
                                <Label text="Flux des demandes" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #475569; -fx-padding: 0 0 10 0;"/>
                                <BarChart fx:id="barChart" title="" VBox.vgrow="ALWAYS"
                                          legendVisible="false" categoryGap="30.0" barGap="5.0"
                                          style="-fx-background-color: transparent;">
                                    <xAxis>
                                        <CategoryAxis label="Date" side="BOTTOM" />
                                    </xAxis>
                                    <yAxis>
                                        <NumberAxis label="Quantité" side="LEFT" />
                                    </yAxis>
                                </BarChart>
                            </children>
                        </VBox>

                        <VBox spacing="20" prefWidth="350.0">
                            <children>
                                <VBox VBox.vgrow="ALWAYS"
                                      style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                                    <children>
                                        <Label text="Répartition des Priorités" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                                        <PieChart fx:id="pieChart" legendSide="BOTTOM" labelsVisible="true" VBox.vgrow="ALWAYS" />
                                    </children>
                                </VBox>

                                <VBox VBox.vgrow="ALWAYS"
                                      style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.05), 10, 0, 0, 5);">
                                    <children>
                                        <Label text="État d'avancement" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #475569;"/>
                                        <PieChart fx:id="statutPieChart" legendSide="BOTTOM" labelsVisible="true" VBox.vgrow="ALWAYS" />
                                    </children>
                                </VBox>
                            </children>
                        </VBox>

                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>