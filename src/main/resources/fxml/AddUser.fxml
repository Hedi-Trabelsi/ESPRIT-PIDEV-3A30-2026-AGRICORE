<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" stylesheets="@shadcn.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.AddUserController">
   <children>
      <HBox layoutX="40.0" layoutY="27.0" prefHeight="273.0" prefWidth="405.0">
         <children>
            <VBox alignment="CENTER" prefHeight="273.0" prefWidth="211.0" spacing="40.0">
               <children>
                  <Label text="Prénom :" />
                  <Label text="Nom :" />
                  <Label text="Email :" />
               </children>
            </VBox>
            <VBox alignment="CENTER" prefHeight="273.0" prefWidth="193.0" spacing="17.0">
               <children>
                  <TextField fx:id="firstNameTf" />
                  <TextField fx:id="lastNameTf" />
                  <TextField fx:id="emailTf" />
               </children>
            </VBox>
         </children>
      </HBox>
      <Button layoutX="478.0" layoutY="311.0" mnemonicParsing="false" onAction="#saveUser" text="Enregistrer" />
      <Button layoutX="470.0" layoutY="27.0" mnemonicParsing="false" onAction="#navigateShowUsers" styleClass="secondary" text="Voir les utilisateurs" />
   </children>
</AnchorPane>
