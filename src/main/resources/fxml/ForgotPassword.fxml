<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:id="rootPane"
           fx:controller="Controller.ForgotPasswordController"
           prefWidth="1200" prefHeight="800"
           styleClass="auth-root-pane"
           stylesheets="@style.css">

    <!-- Decorative Background Elements -->
    <children>
        <Rectangle styleClass="auth-bg-circle1" />
        <Rectangle styleClass="auth-bg-circle2" />

        <!-- Main Card -->
        <VBox alignment="CENTER"
              spacing="30"
              maxWidth="450"
              styleClass="auth-card">

            <padding>
                <Insets top="50" right="50" bottom="50" left="50"/>
            </padding>

            <!-- Logo & Title Section -->
            <VBox alignment="CENTER" spacing="15">
                <Label text="🌱" styleClass="auth-logo-icon"/>
                <Label text="AGRICOR" styleClass="auth-brand-label"/>
                <VBox alignment="CENTER" spacing="5">
                    <Label text="Forgot Password?" styleClass="auth-title-label"/>
                    <Label text="We'll send a code to your email"
                           styleClass="auth-subtitle-label"
                           wrapText="true"
                           alignment="CENTER"/>
                </VBox>
            </VBox>

            <!-- Decorative Divider -->
            <HBox alignment="CENTER" spacing="10">
                <Line startX="0" endX="100" styleClass="auth-divider-line"/>
                <Label text="🌾" styleClass="auth-divider-icon"/>
                <Line startX="0" endX="100" styleClass="auth-divider-line"/>
            </HBox>

            <!-- Step 1: Email Form -->
            <VBox fx:id="emailStep" spacing="20" maxWidth="350">
                <VBox spacing="5">
                    <Label text="Email Address" styleClass="auth-field-label"/>
                    <HBox spacing="10" styleClass="auth-field-container">
                        <Label text="📧" styleClass="auth-field-icon"/>
                        <TextField fx:id="emailField"
                                   promptText="Enter your email"
                                   styleClass="auth-field"/>
                    </HBox>
                </VBox>

                <Button text="Send Login Code"
                        maxWidth="Infinity"
                        prefHeight="45"
                        styleClass="auth-primary-button"
                        onAction="#handleSendCode"/>

                <HBox alignment="CENTER" spacing="8">
                    <Label text="Remember your password?" styleClass="auth-footer-label"/>
                    <Hyperlink text="Sign In" styleClass="auth-signup-link" onAction="#openSignInPage"/>
                </HBox>
            </VBox>

            <!-- Step 2: Code Verification Form (Initially Hidden) -->
            <VBox fx:id="codeStep" spacing="20" maxWidth="350" visible="false" managed="false">
                <VBox spacing="5">
                    <Label text="Verification Code" styleClass="auth-field-label"/>
                    <HBox spacing="10" styleClass="auth-field-container">
                        <Label text="🔑" styleClass="auth-field-icon"/>
                        <TextField fx:id="codeField"
                                   promptText="Enter 6-digit code"
                                   styleClass="auth-field"
                                   maxWidth="200"/>
                    </HBox>
                    <Label fx:id="emailDisplayLabel" text="" styleClass="auth-subtitle-label"/>
                </VBox>

                <Button text="Login with Code"
                        maxWidth="Infinity"
                        prefHeight="45"
                        styleClass="auth-primary-button"
                        onAction="#handleVerifyCode"/>

                <HBox alignment="CENTER" spacing="8">
                    <Label text="Didn't receive code?" styleClass="auth-footer-label"/>
                    <Hyperlink text="Resend" styleClass="auth-signup-link" onAction="#handleResendCode"/>
                </HBox>

                <Hyperlink text="← Back to email" styleClass="auth-forgot-link" onAction="#handleBackToEmail"/>
            </VBox>

            <!-- Message Label -->
            <Label fx:id="messageLabel"
                   text=""
                   wrapText="true"
                   visible="false"
                   styleClass="auth-message-label"
                   alignment="CENTER"/>
        </VBox>
    </children>
</StackPane>