<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="800" prefWidth="1400" styleClass="user-root-pane" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.MaintenancePageController">

    <!-- TOP BAR -->
    <top>
        <VBox styleClass="maintenance-topbar" spacing="10">
            <padding>
                <Insets top="15" right="30" bottom="15" left="30" />
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="20">
                <Button fx:id="backButton" text="← Retour" styleClass="back-button" />
                <Label styleClass="maintenance-title" text="Gestion des Maintenances" />
                <Region HBox.hgrow="ALWAYS" />
            </HBox>
        </VBox>
    </top>

    <!-- CENTER CONTENT - Les vues de maintenance seront chargées ici -->
    <center>
        <StackPane fx:id="contentArea" styleClass="maintenance-content" />
    </center>

</BorderPane>