<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 30; -fx-max-width: 600;" xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" fx:controller="Controller.UpdateEvenementController">
    <padding>
        <Insets top="20" right="20" bottom="20" left="20" />
    </padding>

    <Label style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #1a3c1a;" text="Modifier l'Événement" />

    <Separator />

    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
        <VBox spacing="15">
            <!-- Titre -->
            <VBox spacing="5">
                <Label style="-fx-font-weight: bold; -fx-text-fill: #555;" text="Titre *" />
                <TextField fx:id="titreField" promptText="Titre de l'événement" style="-fx-background-radius: 10; -fx-border-color: #ddd; -fx-padding: 10;" />
            </VBox>

            <!-- Lieu -->
            <VBox spacing="5">
                <Label style="-fx-font-weight: bold; -fx-text-fill: #555;" text="Lieu *" />
                <TextField fx:id="lieuField" promptText="Lieu de l'événement" style="-fx-background-radius: 10; -fx-border-color: #ddd; -fx-padding: 10;" />
            </VBox>

            <!-- Description -->
            <VBox spacing="5">
                <Label style="-fx-font-weight: bold; -fx-text-fill: #555;" text="Description" />
                <TextArea fx:id="descriptionArea" promptText="Description de l'événement" style="-fx-background-radius: 10; -fx-border-color: #ddd; -fx-padding: 10;" prefRowCount="4" wrapText="true" />
            </VBox>

            <!-- Date et Heure de Début -->
            <VBox spacing="5">
                <Label style="-fx-font-weight: bold; -fx-text-fill: #555;" text="Date et Heure de Début *" />
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <DatePicker fx:id="dateDebutPicker" style="-fx-pref-width: 120;" />
                    <ComboBox fx:id="hourDebutCombo" promptText="Heure" style="-fx-pref-width: 70;" />
                    <Label text=":" />
                    <ComboBox fx:id="minDebutCombo" promptText="Min" style="-fx-pref-width: 70;" />
                </HBox>
            </VBox>

            <!-- Date et Heure de Fin -->
            <VBox spacing="5">
                <Label style="-fx-font-weight: bold; -fx-text-fill: #555;" text="Date et Heure de Fin *" />
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <DatePicker fx:id="dateFinPicker" style="-fx-pref-width: 120;" />
                    <ComboBox fx:id="hourFinCombo" promptText="Heure" style="-fx-pref-width: 70;" />
                    <Label text=":" />
                    <ComboBox fx:id="minFinCombo" promptText="Min" style="-fx-pref-width: 70;" />
                </HBox>
            </VBox>

            <!-- Capacité et Frais -->
            <HBox spacing="15">
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #555;" text="Capacité *" />
                    <TextField fx:id="capaciteField" promptText="Nombre de places" style="-fx-background-radius: 10; -fx-border-color: #ddd; -fx-padding: 10;" />
                </VBox>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label style="-fx-font-weight: bold; -fx-text-fill: #555;" text="Frais (DT) *" />
                    <TextField fx:id="fraisField" promptText="Prix en DT" style="-fx-background-radius: 10; -fx-border-color: #ddd; -fx-padding: 10;" />
                </VBox>
            </HBox>

            <!-- Boutons -->
            <HBox spacing="15" alignment="CENTER" style="-fx-padding: 20 0 0 0;">
                <Button fx:id="saveButton" onAction="#saveChanges" style="-fx-background-color: #2d5a27; -fx-text-fill: white; -fx-padding: 12 30; -fx-background-radius: 12; -fx-font-weight: bold; -fx-cursor: hand;" text="Enregistrer" />
                <Button fx:id="cancelButton" style="-fx-background-color: transparent; -fx-text-fill: #888; -fx-padding: 12 30; -fx-background-radius: 12; -fx-cursor: hand;" text="Annuler" />
            </HBox>
        </VBox>
    </ScrollPane>
</VBox>