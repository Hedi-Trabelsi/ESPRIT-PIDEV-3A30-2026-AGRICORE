<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="Controller.ProfileController"
            stylesheets="@style2.css"
            prefWidth="600" prefHeight="500"
            styleClass="profile-pane">

    <!-- Top: Title -->
    <top>
        <Label text="Profile" BorderPane.alignment="CENTER"
               styleClass="profile-title"/>
    </top>

    <!-- Center: Form -->
    <center>
        <GridPane hgap="10" vgap="10">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <columnConstraints>
                <ColumnConstraints halignment="RIGHT" prefWidth="120"/>
                <ColumnConstraints halignment="LEFT" prefWidth="250"/>
            </columnConstraints>

            <!-- Row 0 -->
            <Label text="Nom:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
            <TextField fx:id="nomField" GridPane.rowIndex="0" GridPane.columnIndex="1" editable="false"/>

            <!-- Row 1 -->
            <Label text="Prenom:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
            <TextField fx:id="prenomField" GridPane.rowIndex="1" GridPane.columnIndex="1" editable="false"/>

            <!-- Row 2 -->
            <Label text="Email:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
            <TextField fx:id="emailField" GridPane.rowIndex="2" GridPane.columnIndex="1" editable="false"/>

            <!-- Row 3 -->
            <Label text="Phone:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
            <TextField fx:id="phoneField" GridPane.rowIndex="3" GridPane.columnIndex="1" editable="false"/>

            <!-- Row 4 -->
            <Label text="Genre:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
            <ComboBox fx:id="genreBox" GridPane.rowIndex="4" GridPane.columnIndex="1" disable="true"/>

            <!-- Row 5 -->
            <Label text="Date de Naissance:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
            <DatePicker fx:id="datePicker" GridPane.rowIndex="5" GridPane.columnIndex="1" editable="false"/>

            <!-- Row 6 -->
            <Label text="Role:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
            <Label fx:id="roleLabel" GridPane.rowIndex="6" GridPane.columnIndex="1"/>
        </GridPane>
    </center>

    <!-- Bottom: Buttons -->
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Button fx:id="btnEdit" text="Edit" onAction="#handleEdit"
                    styleClass="profile-button"/>
            <Button fx:id="btnUpdate" text="Update" onAction="#handleUpdate"
                    styleClass="profile-button" visible="false"/>
            <Button text="Logout" onAction="#handleLogout"
                    styleClass="profile-button"/>
        </HBox>
    </bottom>
</BorderPane>
