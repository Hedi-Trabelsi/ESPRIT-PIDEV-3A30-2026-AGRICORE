<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.UpdateUserController"
           prefWidth="600" prefHeight="500"
           style="-fx-background-color: linear-gradient(to bottom right, #1b5e20, #66bb6a);">

    <VBox spacing="20" alignment="CENTER">
        <padding>
            <Insets top="40" right="40" bottom="40" left="40"/>
        </padding>

        <!-- Title -->
        <Label text="✏️ Update User"
               style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: white;"/>

        <!-- Form Fields -->
        <VBox spacing="15" style="-fx-background-color: rgba(255,255,255,0.9); -fx-padding: 20; -fx-background-radius: 15;">
            <TextField fx:id="nomField" promptText="Nom" style="-fx-background-radius: 10;"/>
            <TextField fx:id="prenomField" promptText="Prenom" style="-fx-background-radius: 10;"/>
            <DatePicker fx:id="dateNaissanceField" promptText="Date de Naissance" style="-fx-background-radius: 10;"/>
            <TextField fx:id="adresseField" promptText="Adresse" style="-fx-background-radius: 10;"/>
            <TextField fx:id="phoneField" promptText="Phone" style="-fx-background-radius: 10;"/>
            <ComboBox fx:id="genreField" promptText="Genre" style="-fx-background-radius: 10;"/>
            <TextField fx:id="emailField" promptText="Email" style="-fx-background-radius: 10;"/>
            <PasswordField fx:id="passwordField" promptText="Password" style="-fx-background-radius: 10;"/>
        </VBox>

        <!-- Buttons -->
        <HBox spacing="20" alignment="CENTER">
            <Button text="Update" fx:id="updateButton"
                    style="-fx-background-color: #1b5e20; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-size: 14px;"/>
            <Button text="Cancel" fx:id="cancelButton"
                    style="-fx-background-color: #c62828; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-size: 14px;"/>
        </HBox>

        <Label fx:id="statusLabel" text="" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
    </VBox>
</StackPane>
