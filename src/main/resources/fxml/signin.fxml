<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="org.example.SigninController"
           fx:id="rootPane"
           prefWidth="1000" prefHeight="650"
           styleClass="root-pane"
           stylesheets="@style.css">

    <VBox alignment="CENTER"
          spacing="20"
          maxWidth="400"
          styleClass="card">

        <padding>
            <Insets top="40" right="60" bottom="40" left="60"/>
        </padding>

        <!-- Title -->
        <VBox alignment="CENTER" spacing="5">
            <Label text="🌱 AGRICOR"
                   styleClass="title-label" />
            <Label text="Sign in to your account"
                   styleClass="subtitle-label" />
        </VBox>

        <Separator />

        <!-- FORM -->
        <VBox spacing="15">

            <!-- Email -->
            <TextField fx:id="emailField"
                       promptText="Email"
                       styleClass="modern-field"/>

            <!-- Password -->
            <PasswordField fx:id="passwordField"
                           promptText="Password"
                           styleClass="modern-field"/>

            <!-- Inline Error Label -->
            <Label fx:id="errorLabel"
                   text=""
                   style="-fx-text-fill: red; -fx-font-weight: bold;"
                   wrapText="true"
                   visible="false"/>

            <!-- Sign In Button -->
            <Button fx:id="signinButton"
                    text="Sign In"
                    prefWidth="200"
                    styleClass="primary-button"
                    onAction="#handleSignin"/>

            <!-- Sign Up Link -->
            <HBox alignment="CENTER" spacing="5">
                <Label text="Don't have an account?" styleClass="subtitle-label"/>
                <Hyperlink fx:id="signupLink"
                           text="Sign Up"
                           styleClass="link-style"
                           onAction="#openSignupPage"/>
            </HBox>

            <!-- Forget Password -->
            <Hyperlink fx:id="forgetPasswordLink"
                       text="Forgot Password?"
                       styleClass="link-style"/>
        </VBox>
    </VBox>

</StackPane>
