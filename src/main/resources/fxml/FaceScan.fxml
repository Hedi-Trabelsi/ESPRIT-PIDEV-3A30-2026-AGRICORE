<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10" alignment="CENTER" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml" fx:controller="Controller.FaceScanController">
    <ImageView fx:id="cameraView" fitWidth="320" fitHeight="240"/>
    <Button text="Capture Face" fx:id="captureButton" onAction="#handleCapture"/>
</VBox>